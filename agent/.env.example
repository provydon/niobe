# For voice agent: set GEMINI_API_KEY or GOOGLE_API_KEY (Gemini API), or use Vertex below
# GEMINI_API_KEY=your_key
# PORT=8080

# DB: same as Laravel (agent reads waitresses + writes waitress_action_logs)
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=niobe
# DB_USERNAME=
# DB_PASSWORD=
# DB_SSLMODE=disable

# SMTP for tool actions (e.g. order emails). Same as Laravel MAIL_* if using one app.
# MAIL_HOST=127.0.0.1
# MAIL_PORT=1025
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM_ADDRESS=niobe@local
# MAIL_FROM_NAME=Niobe

GOOGLE_CLOUD_PROJECT=Niobe
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True