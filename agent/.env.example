# Voice agent: Gemini API key, or use Vertex below
GEMINI_API_KEY=
PORT=9000

# DB: same database as Laravel. Use SQLite for local try (path relative to agent/ when running from agent/).
DATABASE_URL=file:../niobe/database/database.sqlite
# For PostgreSQL: postgres://user:password@host:5432/niobe?sslmode=disable

# SMTP for tool actions (e.g. order emails). Same as Laravel MAIL_* if using one app.
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=niobe@local
MAIL_FROM_NAME=Niobe

GOOGLE_CLOUD_PROJECT=Niobe
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True