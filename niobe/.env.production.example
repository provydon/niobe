# Production env for Laravel (niobe). Copy to .env.production and fill in.
# deploy.sh loads this and overrides DB_* and Cloud Run–specific vars.

APP_NAME=Laravel
APP_ENV=production
APP_KEY=base64:your-key-from-php-artisan-key-generate--show
APP_DEBUG=false
APP_URL=https://your-niobe-web-url.run.app

SESSION_DOMAIN=.yourdomain.com
SESSION_DRIVER=database
SESSION_LIFETIME=120
LOG_STACK=single,stderr
CACHE_STORE=database
QUEUE_CONNECTION=database

DB_CONNECTION=pgsql
# DB_* are overridden by deploy.sh from Terraform / Cloud SQL

GEMINI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VOICE_AGENT_URL=https://your-niobe-agent-url.run.app

# Optional: MAIL_*, AWS_*, etc.
